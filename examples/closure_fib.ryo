# closure

# fibonacci is a function that returns
# a function that returns an int.
fn fibonacci() -> fn() -> int:
    a, b = 0, 1
    return fn() -> int:
        if a == 0:
            a, b = 0, 1 # Initialize the first two Fibonacci numbers
        else:
            a, b = b, a+b # Update to the next Fibonacci number
        return a

fn main():
    f = fibonacci()
    for i in range(0,10):
        println(f())

